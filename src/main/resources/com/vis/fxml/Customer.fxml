<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.vis.controller.CustomerController"
            styleClass="root-pane"
            prefWidth="1000" prefHeight="700">

    <top>
        <HBox styleClass="module-nav" alignment="CENTER_LEFT" spacing="4">
            <Button text="🏠  Dashboard" onAction="#goToDashboard" styleClass="nav-home-btn"/>
            <Region HBox.hgrow="NEVER" minWidth="12"/>
            <Button text="🚗  Vehicles"  onAction="#goToVehicles"  styleClass="nav-tab-btn"/>
            <Button text="🔧  Workshop"  onAction="#goToWorkshop"  styleClass="nav-tab-btn"/>
            <Button text="👤  Customers" onAction="#goToCustomers" styleClass="nav-tab-btn nav-tab-active"/>
            <Button text="🚓  Police"    onAction="#goToPolice"    styleClass="nav-tab-btn"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="12" styleClass="content-pane">
            <padding><Insets top="16" right="20" bottom="16" left="20"/></padding>

            <Label text="Customer Management" styleClass="page-title"/>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Button text="Add"    onAction="#handleAdd"    styleClass="primary-btn"/>
                <Button text="Update" onAction="#handleUpdate" styleClass="secondary-btn"/>
                <Button text="Delete" onAction="#handleDelete" styleClass="danger-btn"/>
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="statusLabel" styleClass="status-label"/>
            </HBox>

            <ProgressBar fx:id="progressBar" maxWidth="Infinity" prefHeight="6" styleClass="progress-bar"/>

            <HBox spacing="15" VBox.vgrow="ALWAYS">
                <VBox spacing="10" HBox.hgrow="ALWAYS">
                    <TableView fx:id="customerTable" VBox.vgrow="ALWAYS">
                        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                        <placeholder><Label text="No customers found." styleClass="field-label"/></placeholder>
                        <columns>
                            <TableColumn fx:id="colId"      text="ID"      prefWidth="60"/>
                            <TableColumn fx:id="colName"    text="Name"    prefWidth="180"/>
                            <TableColumn fx:id="colAddress" text="Address" prefWidth="220"/>
                            <TableColumn fx:id="colPhone"   text="Phone"   prefWidth="130"/>
                            <TableColumn fx:id="colEmail"   text="Email"   prefWidth="200"/>
                        </columns>
                    </TableView>

                </VBox>
                
                <TitledPane text="Customer Statistics" expanded="true" collapsible="false" styleClass="form-pane" prefWidth="320" maxHeight="Infinity">
                    <PieChart fx:id="customerChart" title="Customers by Domain" legendVisible="true" legendSide="BOTTOM"/>
                </TitledPane>
            </HBox>




        </VBox>
    </center>
</BorderPane>
