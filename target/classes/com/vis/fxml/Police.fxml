<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.vis.controller.PoliceController"
            styleClass="root-pane"
            prefWidth="1000" prefHeight="700">

    <top>
        <HBox styleClass="module-nav" alignment="CENTER_LEFT" spacing="4">
            <Button text="🏠  Dashboard" onAction="#goToDashboard" styleClass="nav-home-btn"/>
            <Region HBox.hgrow="NEVER" minWidth="12"/>
            <Button text="🚗  Vehicles"  onAction="#goToVehicles"  styleClass="nav-tab-btn"/>
            <Button text="🔧  Workshop"  onAction="#goToWorkshop"  styleClass="nav-tab-btn"/>
            <Button text="👤  Customers" onAction="#goToCustomers" styleClass="nav-tab-btn"/>
            <Button text="🛡️  Insurance" onAction="#goToInsurance" styleClass="nav-tab-btn"/>
            <Button text="🚓  Police"    onAction="#goToPolice"    styleClass="nav-tab-btn nav-tab-active"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="10" styleClass="content-pane">
            <padding><Insets top="16" right="20" bottom="16" left="20"/></padding>

            <Label text="Police Module" styleClass="page-title"/>
            <ProgressBar fx:id="progressBar" maxWidth="Infinity" prefHeight="6" styleClass="progress-bar"/>

            <TabPane VBox.vgrow="ALWAYS" styleClass="tab-pane">

                <Tab text="Police Reports" closable="false">
                    <VBox spacing="10">
                        <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Button text="Add Report" onAction="#handleAddReport" styleClass="primary-btn"/>
                        </HBox>

                        <HBox spacing="15" VBox.vgrow="ALWAYS">
                            <VBox spacing="10" HBox.hgrow="ALWAYS">
                                <TableView fx:id="reportTable" VBox.vgrow="ALWAYS">
                                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                                    <placeholder><Label text="No police reports found." styleClass="field-label"/></placeholder>
                                    <columns>
                                        <TableColumn fx:id="colRepId"      text="ID"          prefWidth="50"/>
                                        <TableColumn fx:id="colRepReg"     text="Vehicle Reg" prefWidth="130"/>
                                        <TableColumn fx:id="colRepDate"    text="Date"        prefWidth="100"/>
                                        <TableColumn fx:id="colRepType"    text="Type"        prefWidth="110"/>
                                        <TableColumn fx:id="colRepDesc"    text="Description" prefWidth="250"/>
                                        <TableColumn fx:id="colRepOfficer" text="Officer"     prefWidth="130"/>
                                    </columns>
                                </TableView>
                            </VBox>
                            
                            <TitledPane text="Report Statistics" expanded="true" collapsible="false" styleClass="form-pane" prefWidth="300" maxHeight="Infinity">
                                <BarChart fx:id="reportChart" title="Reports by Type">
                                    <xAxis><CategoryAxis label="Type" side="BOTTOM" /></xAxis>
                                    <yAxis><NumberAxis label="Count" side="LEFT" /></yAxis>
                                </BarChart>
                            </TitledPane>
                        </HBox>


                    </VBox>
                </Tab>

                <Tab text="Violations" closable="false">
                    <VBox spacing="10">
                        <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Button text="Add Violation" onAction="#handleAddViolation" styleClass="primary-btn"/>
                            <Button text="Mark as Paid"  onAction="#handleMarkPaid"     styleClass="secondary-btn"/>
                        </HBox>

                        <HBox spacing="15" VBox.vgrow="ALWAYS">
                            <VBox spacing="10" HBox.hgrow="ALWAYS">
                                <TableView fx:id="violationTable" VBox.vgrow="ALWAYS">
                                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                                    <placeholder><Label text="No violations found." styleClass="field-label"/></placeholder>
                                    <columns>
                                        <TableColumn fx:id="colVioId"     text="ID"          prefWidth="50"/>
                                        <TableColumn fx:id="colVioReg"    text="Vehicle Reg" prefWidth="130"/>
                                        <TableColumn fx:id="colVioDate"   text="Date"        prefWidth="100"/>
                                        <TableColumn fx:id="colVioType"   text="Type"        prefWidth="130"/>
                                        <TableColumn fx:id="colVioFine"   text="Fine (M)"    prefWidth="100"/>
                                        <TableColumn fx:id="colVioStatus" text="Status"      prefWidth="90"/>
                                    </columns>
                                </TableView>
                            </VBox>
                            
                            <TitledPane text="Violation Statistics" expanded="true" collapsible="false" styleClass="form-pane" prefWidth="300" maxHeight="Infinity">
                                <BarChart fx:id="violationChart" title="Violations by Status">
                                    <xAxis><CategoryAxis label="Status" side="BOTTOM" /></xAxis>
                                    <yAxis><NumberAxis label="Count" side="LEFT" /></yAxis>
                                </BarChart>
                            </TitledPane>
                        </HBox>


                    </VBox>
                </Tab>
            </TabPane>

            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label fx:id="statusLabel" styleClass="status-label"/>
            </HBox>

        </VBox>
    </center>
</BorderPane>
